---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  image?: string;
  type?: 'website' | 'article';
  article?: boolean;
  publishDate?: string;
  modifiedDate?: string;
  author?: string;
  category?: string;
  categorySlug?: string;
  faqSchema?: object;
}

const {
  title,
  description,
  canonical,
  ogImage,
  image,
  type,
  article = false,
  publishDate,
  modifiedDate,
  author,
  category,
  categorySlug,
  faqSchema
} = Astro.props;

const isArticle = type === 'article' || article;

const siteUrl = 'https://andrad.ro';
const siteName = 'Andrad.ro';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : Astro.url.href;
const imageUrl = ogImage || image;
const fullOgImage = imageUrl ? (imageUrl.startsWith('http') ? imageUrl : `${siteUrl}${imageUrl}`) : `${siteUrl}/og-default.jpg`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": siteUrl,
  "description": "Recenzii, comparații și recomandări pentru cele mai bune produse"
};

// Helper to format date to ISO 8601 with time
function formatDateISO(dateStr: string | undefined): string | undefined {
  if (!dateStr) return undefined;
  // If already has time component, return as is
  if (dateStr.includes('T')) return dateStr;
  // Add time component for date-only strings (YYYY-MM-DD -> YYYY-MM-DDT10:00:00+02:00)
  return `${dateStr}T10:00:00+02:00`;
}

const formattedPublishDate = formatDateISO(publishDate);
const formattedModifiedDate = formatDateISO(modifiedDate) || formattedPublishDate;

const articleSchema = isArticle ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": fullOgImage,
  "datePublished": formattedPublishDate,
  "dateModified": formattedModifiedDate,
  "author": {
    "@type": "Person",
    "name": author || "Echipa Andrad.ro"
  },
  "publisher": {
    "@type": "Organization",
    "name": siteName,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/logo.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": fullCanonical
  }
} : null;

// Breadcrumb schema for articles
const breadcrumbSchema = isArticle && category ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Acasă",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": category,
      "item": `${siteUrl}/${categorySlug}/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title
    }
  ]
} : null;

// faqSchema is already a complete schema object when passed from articles
const faqSchemaData = faqSchema || null;
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={fullCanonical} />

  <meta property="og:type" content={isArticle ? 'article' : 'website'} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="ro_RO" />
  {isArticle && formattedPublishDate && <meta property="article:published_time" content={formattedPublishDate} />}
  {isArticle && formattedModifiedDate && <meta property="article:modified_time" content={formattedModifiedDate} />}
  {isArticle && author && <meta property="article:author" content={author} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <title>{title} | {siteName}</title>

  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  {faqSchemaData && <script type="application/ld+json" set:html={JSON.stringify(faqSchemaData)} />}
</head>
<body class="min-h-screen flex flex-col bg-slate-50">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <CookieBanner />
</body>
</html>
