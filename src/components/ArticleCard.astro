---
interface Props {
  title: string;
  slug: string;
  category: string;
  categorySlug: string;
  excerpt: string;
  image?: string;
}

const { title, slug, category, categorySlug, excerpt, image } = Astro.props;
const cleanExcerpt = excerpt?.replace(/<[^>]*>/g, '') || '';
---

<article class="card group">
  <a href={`/${slug}/`} class="block">
    <div class="aspect-[16/10] bg-slate-100 relative overflow-hidden">
      {image ? (
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200">
          <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      )}
    </div>
    <div class="p-5">
      <div class="mb-2.5">
        <span class="inline-block px-2.5 py-1 text-xs font-semibold text-primary-700 bg-primary-50 rounded-md">
          {category}
        </span>
      </div>
      <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-primary-600 transition-colors line-clamp-2 leading-snug">
        {title}
      </h3>
      <p class="text-slate-600 text-sm line-clamp-2 leading-relaxed">
        {cleanExcerpt}
      </p>
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
